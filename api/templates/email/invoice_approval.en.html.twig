{% extends '_layout.html.twig' %}

{% block content %}
<h1 style="margin:0 0 16px;font-size:22px;font-weight:600;color:#15131D;">
  {% if is_test %}<span style="color:#E8A547;">[TEST] </span>{% endif %}{% if is_reminder %}<span style="color:#E8A547;">Reminder</span> — {% endif %}Hello,
</h1>

{% if is_reminder %}
<p style="margin:0 0 16px;padding:10px 14px;background:#FDF6E9;border-left:3px solid #E8A547;border-radius:4px;">
  This is a <strong>reminder</strong> — we already asked for your approval of this work report but haven't received a response yet.
</p>
{% endif %}

<p style="margin:0 0 16px;">
  please find attached a <strong>work report</strong>
  {% if invoice.project_name %}for project <strong>{{ invoice.project_name }}</strong>{% endif %}
  awaiting your approval{% if invoice.client_company_name %} on behalf of <strong>{{ invoice.client_company_name }}</strong>{% endif %}.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;border-collapse:collapse;background:#F4F2FB;border-radius:8px;margin:16px 0;">
  <tr>
    <td style="padding:16px 20px;">
      <table role="presentation" cellpadding="0" cellspacing="0" style="width:100%;font-size:14px;color:#403B52;">
        {% if work_report %}
        <tr>
          <td style="padding:4px 0;color:#7A748C;width:42%;">Report</td>
          <td style="padding:4px 0;font-weight:600;color:#15131D;">{{ work_report.title }}</td>
        </tr>
        <tr>
          <td style="padding:4px 0;color:#7A748C;">Total hours</td>
          <td style="padding:4px 0;font-family:monospace;font-weight:600;">{{ work_report.total_hours|number_format(2, '.', ',') }} h</td>
        </tr>
        <tr>
          <td style="padding:8px 0 0;color:#7A748C;border-top:1px solid #E5E0F4;">Amount</td>
          <td style="padding:8px 0 0;border-top:1px solid #E5E0F4;font-size:18px;font-weight:700;color:#3B2D83;font-family:monospace;">
            {{ work_report.total_amount|number_format(2, '.', ',') }} {{ invoice.currency }}
          </td>
        </tr>
        {% endif %}
      </table>
    </td>
  </tr>
</table>

<p style="margin:16px 0;">
  Once approved, we will send the invoice immediately — <strong>everything is automated</strong>,
  no need to reply. Just click the button below.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" border="0" align="center" style="margin:28px auto;">
  <tr>
    <td align="center" style="background:#DC2626;border-radius:10px;">
      <a href="{{ approval_url }}"
         style="display:inline-block;padding:24px 64px;font-size:18px;font-weight:700;color:#ffffff;text-decoration:none;border-radius:10px;">
        ✓ Approve work report
      </a>
    </td>
  </tr>
</table>

<p style="margin:24px 0 8px;font-size:13px;color:#7A748C;text-align:center;">
  Or copy this link into your browser:<br>
  <a href="{{ approval_url }}" style="color:#3B2D83;word-break:break-all;font-family:monospace;font-size:12px;">{{ approval_url }}</a>
</p>

<p style="margin:16px 0;font-size:13px;color:#5A5470;">
  Full breakdown is in the attached PDF (Vykaz-{{ invoice.varsymbol_or_id }}.pdf).
  The approval page also offers a rejection option with a reason field.
</p>

{% if is_test %}
<p style="margin:24px 0 0;padding:12px;background:#FDF6E9;border-left:2px solid #E8A547;font-size:13px;color:#8B6420;">
  <strong>This is a TEST email.</strong> The client did not receive it and no approval token was generated.
</p>
{% endif %}
{% endblock %}
