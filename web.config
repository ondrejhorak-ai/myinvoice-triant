<?xml version="1.0" encoding="UTF-8"?>
<!--
  MyInvoice.cz — IIS configuration

  - /api/* requesty jdou na api/public/index.php (Slim FrontController)
  - statika ze /styles/, /assets/ jde napřímo
  - vše ostatní → web/dist/index.html (Vue SPA fallback)
  - blokované složky: /api/src/, /api/vendor/, /db/, /private/, /storage/, /log/, /source/

  PHP 8.5 musí být registrováno v IIS jako handler pro *.php (nepřidáváme zde,
  patří to do globální IIS konfigurace).
-->
<configuration>
  <system.webServer>

    <defaultDocument>
      <files>
        <clear />
        <add value="index.html" />
      </files>
    </defaultDocument>

    <httpProtocol>
      <customHeaders>
        <add name="Strict-Transport-Security"  value="max-age=31536000; includeSubDomains" />
        <add name="X-Content-Type-Options"     value="nosniff" />
        <add name="X-Frame-Options"            value="DENY" />
        <add name="Referrer-Policy"            value="same-origin" />
        <!-- Permissions-Policy: blokujeme jen camera/mic/geolocation/payment (rare
             pro fakturaci), explicitně POVOLUJEME accelerometer/gyroscope/magnetometer/
             xr-spatial-tracking pro Cloudflare Turnstile iframe (human-detection
             fingerprinting). Bez toho `[Violation] xr-spatial-tracking is not allowed`
             v console + může způsobit, že Turnstile nedokáže vystavit token. -->
        <add name="Permissions-Policy"         value="camera=(), microphone=(), geolocation=(), payment=(), accelerometer=(self &quot;https://challenges.cloudflare.com&quot;), gyroscope=(self &quot;https://challenges.cloudflare.com&quot;), magnetometer=(self &quot;https://challenges.cloudflare.com&quot;), xr-spatial-tracking=(self &quot;https://challenges.cloudflare.com&quot;)" />
        <add name="Cross-Origin-Opener-Policy"   value="same-origin" />
        <!-- CORP `same-site` (ne `same-origin`) — striktní `same-origin` blokoval
             same-origin GET na /styles/logo.svg z /manual stránky otevřené přes
             target="_blank" (Chrome `ERR_BLOCKED_BY_RESPONSE.NotSameOrigin`).
             `same-site` zachovává ochranu proti cross-domain leakům. -->
        <add name="Cross-Origin-Resource-Policy" value="same-site" />
        <!-- Cross-Origin-Embedder-Policy záměrně vynecháno — `require-corp` by rozbil Turnstile iframe (Cloudflare nevrací CORP header). -->
        <!-- 'unsafe-inline' v script-src — Cloudflare Turnstile potřebuje
             inline JS pro Widget bootstrap (dokumentace doporučuje, alternativa
             je nonce-per-request). Bez něj `400 captcha_failed` na login/forgot. -->
        <!-- script-src: 'self' + Turnstile + Swagger UI CDN (unpkg.com) pro /api/docs
             style-src: unpkg.com pro Swagger UI CSS
             worker-src: blob: — Swagger UI / Redoc / Turnstile používají blob workery
             font-src: data: — Swagger UI / Redoc embedují fonty jako data URIs
             img-src: data: + validator.swagger.io pro validní spec badge -->
        <add name="Content-Security-Policy"
             value="default-src 'self'; img-src 'self' data: https://validator.swagger.io https://cdn.redoc.ly; style-src 'self' 'unsafe-inline' https://unpkg.com; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com https://unpkg.com https://cdn.redoc.ly; worker-src 'self' blob:; font-src 'self' data:; connect-src 'self' https://unpkg.com https://cdn.redoc.ly; frame-src 'self' https://challenges.cloudflare.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'" />
      </customHeaders>
      <redirectHeaders>
        <clear />
      </redirectHeaders>
    </httpProtocol>

    <security>
      <requestFiltering removeServerHeader="true">
        <!--
          IIS hiddenSegments NESMÍ obsahovat '/' nebo '\' — jen jedno-segmentová jména.
          Pro composite cesty (api/src, api/vendor) máme rewrite rule "Block sensitive directories" níže.
          Tyto segmenty se blokují globálně (kdekoli v URL):
        -->
        <hiddenSegments>
          <add segment="vendor" />
          <add segment="node_modules" />
          <add segment="db" />
          <add segment="private" />
          <add segment="storage" />
          <add segment="log" />
          <add segment="source" />
          <add segment="tools" />
          <add segment=".git" />
          <add segment=".vscode" />
          <add segment=".claude" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".sql" allowed="false" />
          <add fileExtension=".pem" allowed="false" />
          <add fileExtension=".log" allowed="false" />
          <add fileExtension=".lock" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>

    <staticContent>
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
      <remove fileExtension=".webp" />
      <mimeMap fileExtension=".webp" mimeType="image/webp" />
      <!-- OpenAPI spec — servíruje se přímo z api/openapi.yaml jako statický soubor.
           IIS by jinak vrátil 404.3 (neznámý MIME). Při změně specu netřeba PHP. -->
      <remove fileExtension=".yaml" />
      <mimeMap fileExtension=".yaml" mimeType="application/yaml" />
      <!-- Default cache 1 rok pro statiku s hashem (assets, fonty) -->
      <clientCache cacheControlMode="UseMaxAge" cacheControlMaxAge="365.00:00:00" />
    </staticContent>

    <!-- index.html (a /api/*) MUSÍ být no-cache, aby browser dostal aktuální verzi
         hashed assets. /api/* už má no-store v aplikaci. Pro index.html přepisujeme níže rewriteu.
         IIS nemůže elegantně override clientCache per URL — řešení přes outboundRule. -->
    <rewrite>
      <outboundRules>
        <!-- index.html → Cache-Control: no-cache (vždy fresh manifest) -->
        <rule name="HTML no-cache" preCondition="IsHTML">
          <match serverVariable="RESPONSE_Cache_Control" pattern=".*" />
          <action type="Rewrite" value="no-cache, no-store, must-revalidate" />
        </rule>
        <preConditions>
          <preCondition name="IsHTML">
            <add input="{RESPONSE_Content_Type}" pattern="^text/html" />
          </preCondition>
        </preConditions>
      </outboundRules>
      <rules>
        <!-- 0) HTTP → HTTPS 301 redirect — vyjma:
             - loopback / localhost (lokální dev a Docker port-forward)
             - RFC1918 privátní IP (LAN nasazení bez TLS — typicky self-hosted Docker)
             - .local mDNS jména
             - requests už HTTPS, nebo terminované TLS na reverse proxy (X-Forwarded-Proto) -->
        <rule name="HTTPS redirect" stopProcessing="true">
          <match url="(.*)" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTPS}" pattern="off" ignoreCase="true" />
            <add input="{HTTP_X_FORWARDED_PROTO}" pattern="^https$" ignoreCase="true" negate="true" />
            <add input="{HTTP_HOST}" pattern="^localhost(:\d+)?$" ignoreCase="true" negate="true" />
            <add input="{HTTP_HOST}" pattern="^127\." negate="true" />
            <add input="{HTTP_HOST}" pattern="^10\." negate="true" />
            <add input="{HTTP_HOST}" pattern="^192\.168\." negate="true" />
            <add input="{HTTP_HOST}" pattern="^172\.(1[6-9]|2[0-9]|3[0-1])\." negate="true" />
            <add input="{HTTP_HOST}" pattern="\.local(:\d+)?$" ignoreCase="true" negate="true" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}/{R:1}" redirectType="Permanent" />
        </rule>

        <!-- 1) /api/* → api/public/index.php -->
        <rule name="API" stopProcessing="true">
          <match url="^api/(.*)$" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="api/public/index.php" appendQueryString="true" />
        </rule>

        <!-- 2) Bezpečnostní bariéra: blokovat přístup k /private, /db, /log, /source, /storage, /tools, /api/src, /api/vendor, /node_modules -->
        <rule name="Block sensitive directories" stopProcessing="true">
          <match url="^(private|db|log|source|storage|tools|node_modules|api/(src|vendor|templates|tests|bin))(/.*)?$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>

        <!-- 2b) Blokuj cfg.php a další citlivé soubory v rootu (i .md zdrojové
             manuálu — uživatel ho dostane jen v HTML rendru přes /manual). -->
        <rule name="Block sensitive files" stopProcessing="true">
          <match url="^(cfg\.php|cfg\.local\.php|composer\.(json|lock)|\.gitignore|\.env.*|.*\.md|.*\.sql)$" />
          <action type="CustomResponse" statusCode="403" statusReason="Forbidden" statusDescription="Forbidden" />
        </rule>

        <!-- 3) /styles/* fall-through (statika v rootu existuje) -->

        <!-- 3b) /assets/* → web/dist/assets/* (statické bundly Vite) -->
        <rule name="Vite assets" stopProcessing="true">
          <match url="^assets/(.*)$" />
          <action type="Rewrite" url="web/dist/assets/{R:1}" />
        </rule>

        <!-- 3c) /manual a /manual?ch=... → manual/index.php (HTML manuál).
             Statické soubory v /manual/img/ a /manual/generated/ se servírují přímo
             (real file existuje), tady jen "pretty" /manual URL. -->
        <rule name="Manual route" stopProcessing="true">
          <match url="^manual/?$" />
          <action type="Rewrite" url="manual/index.php" appendQueryString="true" />
        </rule>

        <!-- 3c) Některé soubory v rootu projektu, které frontend referencuje (favicon atd.) — fall-through -->

        <!-- 4a) Root URL "/" → web/dist/index.html (samostatně, protože IsDirectory by SPA rule odmítlo) -->
        <rule name="Root SPA index" stopProcessing="true">
          <match url="^$" />
          <action type="Rewrite" url="web/dist/index.html" />
        </rule>

        <!-- 4b) SPA fallback — co není soubor/adresář a nezačíná /api → index.html z web/dist -->
        <rule name="SPA fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile"      negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_URI}"      pattern="^/api/"        negate="true" />
          </conditions>
          <action type="Rewrite" url="web/dist/index.html" />
        </rule>
      </rules>
    </rewrite>

  </system.webServer>
</configuration>
